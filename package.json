{
  "name": "bhyve-mqtt",
  "version": "0.3.1",
  "description": "A MQTT gateway for the unofficial Orbit B-Hyve API indended for use with HomeAssistant",
  "main": "src/app.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/billchurch/bhyve-mqtt.git"
  },
  "keywords": [
    "orbit bhyve",
    "homeassistant",
    "mqtt"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node src/app.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "ci": "npm run test && npm run build",
    "test": "eslint . --max-warnings 0",
    "build": "echo \"No build step needed\""
  },
  "type": "module",
  "files": [
    "src/",
    "LICENSE",
    "README.md",
    "CHANGELOG.md",
    ".env-sample"
  ],
  "author": "bill church",
  "license": "MIT",
  "dependencies": {
    "ajv": "^8.17.1",
    "bhyve-api": "^1.2.4",
    "debug": "^4.4.3",
    "dotenv": "^17.2.3",
    "mqtt": "^5.14.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^10.0.1",
    "eslint": "^9.37.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-n": "^17.23.1",
    "eslint-plugin-prettier": "^5.5.4",
    "prettier": "^3.6.2"
  }
}
